# GitLab CI Configuration for AI Code Review
# Copy this to .gitlab-ci.yml in your project

stages:
  - review

# AI Code Review job
# Runs on merge request pipelines
ai_code_review:
  image:
    name: ghcr.io/shpyntov/gitlab_mr_ai_reviewer:latest
  stage: review
  rules:
    # Only run on merge request pipelines
    - if: $CI_PIPELINE_SOURCE == "merge_request_event"
    - if: $CI_MERGE_REQUEST_ID
  script:
    - python -m reviewbot.main
  allow_failure: true  # Don't block MR on review failures
  timeout: 10m
  variables:
    # Optional: Override default LLM settings
    # LLM_MODEL: "Qwen/Qwen3-Coder-480B-A35B-Instruct"
    # LLM_TEMPERATURE: "0.3"
    # REVIEW_LANGUAGE: "ru"

